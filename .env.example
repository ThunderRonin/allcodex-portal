# ── AllCodex Portal Environment Variables ──────────────────────────────────

# AllCodex Core (Trilium ETAPI)
# URL of the running AllCodex Core server (default: http://localhost:8080)
ALLCODEX_URL=http://localhost:8080
# ETAPI token from AllCodex Core settings → API → ETAPI tokens
ALLCODEX_ETAPI_TOKEN=

# AllKnower (AI orchestration service)
# URL of the running AllKnower server (default: http://localhost:3001)
ALLKNOWER_URL=http://localhost:3001
# Bearer token created when you first register via /api/config/allknower-register
ALLKNOWER_BEARER_TOKEN=

# Lore root note (optional)
# The AllCodex note ID that serves as the parent for all lore entries.
# Defaults to "root" (the AllCodex root note) if not set.
# LORE_ROOT_NOTE_ID=root
